# Snakefile: metatranscriptomics -> MetaPhlAn

import os
import glob

# Directories containing de-rRNA fastq files
input_dirs = [
    "/project/blekhman/sjarif/konzo/02_MT_trim_dehost_rRNAremove/ribodetector",
    "/project/blekhman/sjarif/konzo/02_MT_trim_dehost_rRNAremove_HMP/ribodetector"
]

# Output directory
output_dir = "/scratch/midway3/sjarif/08_MT_metaphlan"

# Find all R1 fastqs in input dirs
r1_fastqs = []
for d in input_dirs:
    r1_fastqs.extend(glob.glob(os.path.join(d, "*_R1*.fastq.gz")))

# Extract sample names from filenames
SAMPLES = [os.path.basename(f).replace("_R1.fastq.gz","").replace("_R1_001.fastq.gz","") for f in r1_fastqs]

# Create paired-end mapping
PAIR_DICT = {s: {"R1": glob.glob(os.path.join(d, f"{s}_R1*.fastq.gz"))[0],
                 "R2": glob.glob(os.path.join(d, f"{s}_R2*.fastq.gz"))[0]} 
             for s in SAMPLES for d in input_dirs if glob.glob(os.path.join(d, f"{s}_R1*.fastq.gz"))}

# Default rule
rule all:
    input:
        expand(os.path.join(output_dir, "{sample}_profiled.tsv"), sample=SAMPLES)

# MetaPhlAn profiling rule
rule metaphlan_profile:
    input:
        R1=lambda wildcards: PAIR_DICT[wildcards.sample]["R1"],
        R2=lambda wildcards: PAIR_DICT[wildcards.sample]["R2"]
    output:
        tsv=os.path.join(output_dir, "{sample}_profiled.tsv"),
        json=os.path.join(output_dir, "{sample}_profiled.json")
    params:
        # Adjust this path if MetaPhlAn database is in a custom location
        db="/project/blekhman/shared/metaphlan_db"
    threads: 8
    shell:
        """
        metaphlan {input.R1},{input.R2} \
            --input_type fastq \
            --bowtie2db {params.db} \
            --nproc {threads} \
            --bowtie2out {output.tsv}.bt2.bz2 \
            --output_file {output.tsv} \
            --output_json {output.json}
        """

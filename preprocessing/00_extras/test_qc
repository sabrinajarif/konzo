# first run fastqc to figure out what adapter sequences are
module load fastqc
mkdir fastqc_raw
export _JAVA_OPTIONS="-Xmx60g"

# Loop through each pair of samples in the directory
# Ran this in the login node because its only 3 samples
# Goal is to know what the primer/ adapter sequences are
for pair in "$testfile_dir"/*_R1_001.fastq.gz; do
    # Get the base name of the R1 file
    base_name=$(basename "$pair" _R1_001.fastq.gz)
    
    # Define the R2 file name based on the base name of R1
    sample1="$pair"
    sample2="$testfile_dir/${base_name}_R2_001.fastq.gz"
    
    # Run FastQC on both samples in the pair
    fastqc "$sample1" "$sample2"
done


exit

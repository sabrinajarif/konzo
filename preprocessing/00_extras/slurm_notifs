# Create notifier script

#!/bin/bash

JOB_ID=$1
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/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"
CHANNEL="#slurm"  # Replace with your actual Slack channel
USERNAME="slurm-bot"
TEXT="Your Slurm job with ID $JOB_ID has finished."

# Send notification to Slack
payload="{
  \"channel\": \"$CHANNEL\",
  \"username\": \"$USERNAME\",
  \"text\": \"$TEXT\"
}"

{
  echo "Received job ID: $JOB_ID. Sending slack notification..."
  curl -sS -X POST -H 'Content-type: application/json' --data "$payload" $SLACK_WEBHOOK_URL
  echo "Notification sent for job $JOB_ID."
} > notification_output.txt 2>&1


# Make executable
chmod +x job_script.sh
chmod +x send_slack_notification.sh

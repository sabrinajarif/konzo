# ----------------------------------------------------------
# CONFIGURATION
# ----------------------------------------------------------
SAMPLES = ["sample1", "sample2", "sample3"]  # list your sample names
CONTIGS = "02_ASSEMBLY/final_contigs.fa"
CONTIGS_DB = "05_CONTIGS_DB/contigs.db"
THREADS = 8

# input read paths
READS_DIR = "01_QC/"
R1 = lambda wildcards: f"{READS_DIR}/{wildcards.sample}_R1.fastq.gz"
R2 = lambda wildcards: f"{READS_DIR}/{wildcards.sample}_R2.fastq.gz"

# ----------------------------------------------------------
# RULE ALL
# ----------------------------------------------------------
rule all:
    input:
        expand("03_MAPPING/{sample}/{sample}_sorted.bam.bai", sample=SAMPLES),
        expand("04_PROFILES/{sample}/PROFILE.db", sample=SAMPLES),
        "mapping_summary.tsv"

# ----------------------------------------------------------
# BUILD BOWTIE2 INDEX
# ----------------------------------------------------------
rule make_index:
    input:
        CONTIGS
    output:
        expand("02_ASSEMBLY/final_contigs.{ext}.bt2", ext=["1","2","3","4","rev.1","rev.2"])
    shell:
        "bowtie2-build {input} 02_ASSEMBLY/final_contigs"

# ----------------------------------------------------------
# ALIGN READS
# ----------------------------------------------------------
rule align:
    input:
        idx = "02_ASSEMBLY/final_contigs",
        r1 = R1,
        r2 = R2
    output:
        temp("03_MAPPING/{sample}/{sample}.bam")
    threads: THREADS
    log:
        "logs/{sample}_align.log"
    shell:
        """
        mkdir -p $(dirname {output})
        bowtie2 -x {input.idx} -1 {input.r1} -2 {input.r2} \
            --threads {threads} 2> {log} | \
            samtools view -bS - > {output}
        """

# ----------------------------------------------------------
# SORT AND INDEX BAM
# ----------------------------------------------------------
rule sort_and_index:
    input:
        "03_MAPPING/{sample}/{sample}.bam"
    output:
        bam = "03_MAPPING/{sample}/{sample}_sorted.bam",
        bai = "03_MAPPING/{sample}/{sample}_sorted.bam.bai"
    threads: THREADS
    shell:
        """
        samtools sort -@ {threads} -o {output.bam} {input}
        samtools index {output.bam}
        """

# ----------------------------------------------------------
# PROFILE BAM WITH ANVIO
# ----------------------------------------------------------
rule profile:
    input:
        bam = "03_MAPPING/{sample}/{sample}_sorted.bam",
        contigs_db = CONTIGS_DB
    output:
        directory("04_PROFILES/{sample}")
    threads: THREADS
    shell:
        """
        anvi-profile -i {input.bam} -c {input.contigs_db} \
                     -o {output} --num-threads {threads}
        """

# ----------------------------------------------------------
# EXTRACT MAPPING RATES FROM LOGS
# ----------------------------------------------------------
rule summarize_mapping:
    input:
        expand("logs/{sample}_align.log", sample=SAMPLES)
    output:
        "mapping_summary.tsv"
    run:
        import re, pandas as pd
        data = []
        for log in input:
            sample = log.split("/")[-1].replace("_align.log", "")
            with open(log) as f:
                text = f.read()
            match = re.search(r"(\d+\.\d+)% overall alignment rate", text)
            rate = float(match.group(1)) if match else None
            data.append({"sample": sample, "alignment_rate(%)": rate})
        pd.DataFrame(data).to_csv(output[0], sep="\t", index=False)

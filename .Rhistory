DRC_plot_taxon_expression
HMP_plot_taxon_expression <- plot_taxon_expression(HMP_genus_expression, "genus")
HMP_plot_taxon_expression
library(dplyr)
library(readr)
library(purrr)
library(ggplot2)
library(tidyr)
DRC_MT_meta <- read.csv("../metadata/MT_DRC_samp_select_meta.csv") %>%
dplyr::mutate(Sample.ID = as.character(Sample.ID))
DRC_MG_meta <- read.csv("../metadata/Konzo_Metagenomics_2021_Meta.csv") %>%
dplyr::filter(Sample_ID %in% DRC_MT_meta$Sample.ID)
DRC_MG_MT <- DRC_MG_meta %>%
left_join(DRC_MT_meta, by = c("Sample_ID" = "Sample.ID")) %>%
dplyr::select(Sample_ID, DNA_ID, RNA) %>%
dplyr::rename(RNA_ID = RNA)
DRC_MG_wide <- read.csv("data/DRC_MG_tax.tsv", sep="\t")
DRC_sample_cols <- names(DRC_MG_wide)
DRC_sample_cols <- setdiff(
names(DRC_MG_wide),
c("scg_name", "percent_identity", "t_domain", "t_phylum", "t_class",
"t_order", "t_family", "t_genus", "t_species")
)
DRC_MG_genus_agg <- DRC_MG_wide %>%
group_by(t_genus) %>%
summarise(across(all_of(DRC_sample_cols), sum, na.rm = TRUE)) %>%
ungroup()
DRC_genus_DNA_long <- DRC_MG_genus_agg %>%
pivot_longer(-t_genus, names_to = "DNA_ID2", values_to = "DNA")
DRC_genus_RNA_long <- DRC_genus_expression[["wide"]] %>%
rename(genus = taxon) %>%
pivot_longer(-genus, names_to = "RNA_ID2", values_to = "RNA")
library(stringr)
# Pull DNA sample names from your long table
DNA_names <- setNames(as.data.frame(DRC_sample_cols), "DNA_ID2") %>%
mutate(
# remove leading "s"
DNA_ID = str_remove(DNA_ID2, "^s"),
# keep only up to the first underscore (this keeps the "D")
DNA_ID = str_extract(DNA_ID, "^[^_]+"),
DNA_ID = as.character(DNA_ID),
DNA_ID2 = as.character(DNA_ID2))
# Pull RNA sample names from your long table
RNA_names <- setNames(as.data.frame(unique(DRC_genus_RNA_long$RNA_ID2)), "RNA_ID2") %>%
mutate(
RNA_ID = sub("^X", "", RNA_ID2),       # remove leading X
RNA_ID = sub("_.*$", "", RNA_ID),
RNA_ID = as.character(RNA_ID),
RNA_ID2 = as.character(RNA_ID2))
DRC_MG_MT <- DRC_MG_MT %>%
left_join(DNA_names, by="DNA_ID") %>%
left_join(RNA_names, by="RNA_ID")
DRC_genus_DNA_long_filt <- DRC_genus_DNA_long %>%
left_join(DRC_MG_MT, by="DNA_ID2")
DRC_genus_RNA_long_filt <- DRC_genus_RNA_long %>%
left_join(DRC_MG_MT, by="RNA_ID2")
DRC_genus_rel <- DRC_genus_DNA_long_filt %>%
dplyr::filter(!t_genus=="None") %>%
dplyr::filter(Sample_ID %in% DRC_genus_RNA_long_filt$Sample_ID) %>%
group_by(Sample_ID) %>%
mutate(rel_abundance = DNA / sum(DNA, na.rm = TRUE)) %>%
ungroup()
DRC_top_genera <- DRC_genus_rel %>%
group_by(t_genus) %>%
summarise(total_abundance = sum(rel_abundance, na.rm = TRUE)) %>%
arrange(desc(total_abundance)) %>%
slice_head(n = 15) %>%
pull(t_genus)
DRC_genus_rel_top <- DRC_genus_rel %>%
mutate(
genus_plot = ifelse(t_genus %in% DRC_top_genera, t_genus, "Other")
) %>%
group_by(Sample_ID, genus_plot) %>%
summarise(rel_abundance = sum(rel_abundance), .groups = "drop") %>%
dplyr::mutate(genus_plot = factor(genus_plot, levels = c(DRC_top_genera, "Other")))
# Number of top genera
n_top <- length(DRC_top_genera)
# Create a palette of n_top distinct colors from Set3
colors_top <- colorRampPalette(brewer.pal(12, "Set3"))(n_top)
# Add grey for "Other"
colors <- c(colors_top, "grey70")
ggplot(DRC_genus_rel_top, aes(x = Sample_ID, y = rel_abundance, fill = genus_plot)) +
geom_bar(stat = "identity", width = 0.9) +
labs(
x = "Sample",
y = "Relative DNA Abundance",
fill = "Genus"
) +
scale_fill_manual(values = colors) +
theme_linedraw() +
theme(
axis.text.x = element_blank(),
axis.ticks.x = element_blank(),
panel.grid = element_blank(),
legend.text = element_text(face = "italic")
)
ggsave("figs/DRC_DNArelabun.png", height=4, width=6.5)
# filter for genera that are present in at least 30% of DRC samples
DRC_sample_cols <- unique(DRC_genus_DNA_long_filt$DNA_ID2)
DRC_genus_keep <- DRC_MG_genus_agg %>%
rowwise() %>%
mutate(
present_samples = sum(c_across(all_of(DRC_sample_cols)) > 0, na.rm = TRUE),
total_abundance = sum(c_across(all_of(DRC_sample_cols)), na.rm = TRUE)  # optional metric
) %>%
ungroup() %>%
filter(present_samples >= 0.3 * length(DRC_sample_cols)) %>%
arrange(desc(total_abundance)) %>%  # sort by total abundance
#slice_head(n = 10) %>%              # take top 20
pull(t_genus)
# Merge
DRC_RNA_DNA_plot_df <- DRC_genus_DNA_long_filt %>%
rename(genus = t_genus) %>%
left_join(DRC_genus_RNA_long_filt, by = c("genus", "Sample_ID")) %>%
filter(genus %in% DRC_genus_keep) %>%
mutate(RNA_DNA_ratio = RNA / DNA) %>%
dplyr::filter(!RNA_DNA_ratio == "Inf") %>%
dplyr::filter(!RNA_DNA_ratio == "NaN") %>%
mutate(log2_ratio = log2(RNA_DNA_ratio)) %>%
dplyr::filter(log2_ratio != "-Inf")
DRC_RNA_DNA_stats <- DRC_RNA_DNA_plot_df %>%
filter(!genus %in% c("Unclassified", "not_classified_at_genus_level")) %>%
group_by(genus) %>%
summarise(
DNA_mean = mean(DNA, na.rm = TRUE),
DNA_sd   = sd(DNA, na.rm = TRUE),
RNA_mean = mean(RNA, na.rm = TRUE),
RNA_sd   = sd(RNA, na.rm = TRUE),
spearman_rho = cor(DNA, RNA, method = "spearman", use = "pairwise.complete.obs")
) %>%
ungroup() %>%
mutate(log_deviation = log2(RNA_mean / DNA_mean))
DRC_top_extreme <- DRC_RNA_DNA_stats %>%
slice_max(log_deviation, n = 60)  # top 5 deviating genera
HMP_MG_long <- read.csv("data/HMP_MG_tax_long.txt", sep="\t")
HMP_MG_wide <- HMP_MG_long %>%
pivot_wider(
id_cols = c(taxon, taxonomic_level),
names_from = c(metagenome_name),
values_from = coverage
)
HMP_MG_wide2 <- HMP_MG_wide %>%
mutate(
rank = sub("^t_", "", taxonomic_level)
)
HMP_MG_wide_with_lineage <- HMP_MG_wide2 %>%
left_join(
DRC_taxid_with_lineage,
by = c("taxon" = "name", "rank" = "rank")
)
HMP_sample_cols <- unique(HMP_MG_long$metagenome_name)
# aggregate by genus
HMP_MG_genus_agg <- HMP_MG_wide_with_lineage %>%
group_by(genus) %>%
summarise(across(all_of(HMP_sample_cols), sum, na.rm = TRUE)) %>%
ungroup()
HMP_genus_DNA_long <- HMP_MG_genus_agg %>%
pivot_longer(-genus, names_to = "sample", values_to = "DNA") %>%
mutate(sample = sub("^sample", "", sample))
HMP_genus_RNA_long <- HMP_genus_expression[["wide"]] %>%
rename(genus = taxon) %>%
pivot_longer(-genus, names_to = "sample", values_to = "RNA")
# filter for genera that are present in at least 30% of HMP samples
sample_cols <- grep("^sample", names(HMP_MG_genus_agg), value = TRUE)
HMP_genus_keep <- HMP_MG_genus_agg %>%
rowwise() %>%
mutate(present_samples = sum(c_across(all_of(sample_cols)) > 0, na.rm = TRUE)) %>%
ungroup() %>%
filter(present_samples >= 0.3 * length(sample_cols)) %>%
pull(genus)
HMP_genus_keep
# Merge
HMP_RNA_DNA_plot_df <- HMP_genus_DNA_long %>%
left_join(HMP_genus_RNA_long, by = c("genus", "sample")) %>%
filter(genus %in% HMP_genus_keep) %>%
mutate(RNA_DNA_ratio = RNA / DNA) %>%
dplyr::filter(!RNA_DNA_ratio == "Inf") %>%
dplyr::filter(!RNA_DNA_ratio == "NaN") %>%
mutate(log2_ratio = log2(RNA_DNA_ratio))
HMP_RNA_DNA_stats <- HMP_RNA_DNA_plot_df %>%
filter(!genus %in% c("Unclassified", "not_classified_at_genus_level")) %>%
group_by(genus) %>%
summarise(
DNA_mean = mean(DNA, na.rm = TRUE),
DNA_sd   = sd(DNA, na.rm = TRUE),
RNA_mean = mean(RNA, na.rm = TRUE),
RNA_sd   = sd(RNA, na.rm = TRUE)
) %>%
ungroup() %>%
mutate(deviation = abs(RNA_mean - DNA_mean))
HMP_top_extreme <- HMP_RNA_DNA_stats %>%
slice_max(deviation, n = 10)  # top 5 deviating genera
plot_RNA_DNA_genus <- function(plot_df, stats_df, top_extreme, x_col = "DNA", y_col = "RNA",
x_mean_col = "DNA_mean", y_mean_col = "RNA_mean",
genus_col = "genus", deviation="log_deviation", top_n_colors = 12) {
library(ggplot2)
library(RColorBrewer)
library(ggrepel)
# get unique genera
genus_levels <- unique(plot_df[[genus_col]])
n_colors <- length(genus_levels)
# create color palette
palette <- RColorBrewer::brewer.pal(min(n_colors, top_n_colors), "Set3")
if(n_colors > top_n_colors){
palette <- colorRampPalette(RColorBrewer::brewer.pal(top_n_colors, "Set3"))(n_colors)
}
palette_named <- setNames(palette, genus_levels)
# plot
ggplot() +
# individual points
#    geom_point(
#      data = plot_df,
#      aes_string(x = x_col, y = y_col, color = genus_col),
#      alpha = 0.3, size = 2
#    ) +
# mean points with black border
geom_point(
data = stats_df,
aes_string(x = x_mean_col, y = y_mean_col, fill=deviation), #fill = genus_col
shape = 21,
color = "black",
size = 3,
stroke = 0.2
) +
ggrepel::geom_text_repel(
data = top_extreme,
aes(x = DNA_mean, y = RNA_mean, label = genus),
size = 4,
box.padding = 0.3,
fontface = "italic"
) +
# reference line (y=x)
geom_abline(slope = 1, intercept = 0, linetype = "dashed", color = "gray") +
# regression line through means
#    geom_smooth(
#      data = stats_df,
#      aes_string(x = x_mean_col, y = y_mean_col),
#      method = "lm",
#      se = FALSE,
#      color = "black"
#    ) +
# log scales
scale_x_log10() +
scale_y_log10() +
# color/fill scale
#scale_color_manual(values = palette_named) +
#scale_fill_manual(values = palette_named) +
scale_fill_gradient2(  low = "blue",
mid = "white",
high = "red",
midpoint = 1,) +
# labels
labs(x = "DNA",
y = "RNA",
color = "Genus",
fill = "Genus") +
theme_linedraw() +
theme(legend.position = "none")
}

colored_taxa
),
setNames(
c("grey80", "grey50", "grey20"),
c(other_label, not_classified_label, "Unclassified")
)
)
## ----------------------------
## Absolute plot
## ----------------------------
p_abs <- ggplot(
taxon_expr_long,
aes(x = sample, y = coverage, fill = taxon_plot)
) +
geom_bar(stat = "identity") +
theme_bw() +
labs(
title = paste("Top", tax_level, "contributing to gene expression"),
y = "Coverage",
x = "Sample",
fill = tax_level
) +
theme(axis.text.x = element_text(angle = 90, hjust = 1)) +
scale_fill_manual(
values = fill_colors,
breaks = c(colored_taxa, grey_taxa)
)
## ----------------------------
## Relative plot
## ----------------------------
taxon_expr_long_r <- taxon_expr_long %>%
group_by(sample) %>%
mutate(coverage = coverage / sum(coverage)) %>%
ungroup()
p_rel <- ggplot(
taxon_expr_long_r,
aes(x = sample, y = coverage, fill = taxon_plot)
) +
geom_bar(stat = "identity") +
theme_bw() +
labs(
title = paste("Relative contribution of", tax_level, "to gene expression"),
y = "Fraction of coverage",
x = "Sample",
fill = tax_level
) +
theme(axis.text.x = element_text(angle = 90, hjust = 1)) +
scale_fill_manual(
values = fill_colors,
breaks = c(colored_taxa, grey_taxa)
)
## ----------------------------
## Return everything
## ----------------------------
list(
absolute_plot = p_abs,
relative_plot = p_rel
)
}

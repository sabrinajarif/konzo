dplyr::filter(genus %in% c(DRC_top_genera, "Bacteroides"))
plot_RNA_DNA_genus(DRC_RNA_DNA_plot_df, DRC_RNA_DNA_stats, DRC_interesting)
ggsave("figs/DRC_DNAx_RNAy.png", height=4.5, width=5)
library(ggplot2)
library(dplyr)
plot_df <- DRC_RNA_DNA_plot_df %>%
dplyr::filter(genus %in% c(DRC_top_genera)) %>%
left_join(
DRC_genus_rel[, c("Sample_ID", "rel_abundance", "t_genus")],
by = c("genus" = "t_genus", "Sample_ID" = "Sample_ID")
)
# Calculate mean ± SD on log2 ratio for each genus
plot_stats <- plot_df %>%
# remove cases where ratio is zero
dplyr::filter(log2_ratio != "-Inf") %>%
group_by(genus) %>%
summarise(
mean_log2 = mean(log2_ratio, na.rm = TRUE),
sd_log2   = sd(log2_ratio, na.rm = TRUE),
rel_DNA = mean(rel_abundance, na.rm = TRUE),
.groups = "drop"
)
# Order genera by deviation from DRC_top_extreme
plot_stats <- plot_stats %>%
left_join(DRC_RNA_DNA_stats %>% select(genus, log_deviation), by = "genus") %>%
arrange(desc(sd_log2)) %>%
mutate(genus = factor(genus, levels = genus))
plot_df <- plot_df %>%
mutate(genus = factor(genus, levels = levels(plot_stats$genus)))
tile_x <- max(plot_stats$mean_log2 + plot_stats$sd_log2, na.rm = TRUE) + 0.5
# Lollipop plot
ggplot() +
# individual points
geom_jitter(
data = plot_df,
aes(x = log2_ratio, y = genus),
height = 0.1, width = 0, alpha = 0.2, color = "grey30", size = 1.5
) +
# error bars
geom_errorbarh(
data = plot_stats,
aes(y = genus, xmin = mean_log2 - sd_log2, xmax = mean_log2 + sd_log2),
height = 0.4, color = "black", alpha = 0.8
) +
# mean points
geom_point(
data = plot_stats,
aes(x = mean_log2, y = genus),
shape=21,
fill = "black",
color="black",
size = 2.5
) +
# SD tiles on the right
geom_tile(
data = plot_stats,
aes(
x = 12,
y = genus,
fill = sd_log2
),
width = 1, height = 0.8
) +
scale_fill_gradient2() +
# vertical 1:1 line
geom_vline(xintercept = log2(1), linetype = "dashed", color = "black") +
labs(
x = "log2(RNA:DNA ratio)",
y = "Genus"
) +
theme_linedraw() +
theme(
axis.text.y = element_text(size = 9, face="italic"),
panel.grid.major.y = element_blank(),
panel.grid.minor = element_blank()
)
ggsave("figs/sd_DRC.png", height=3, width=6)
genera_of_interest <- c("Faecalibacterium", "Roseburia", "Bacteroides") #"Alistipes", #"Phocaeicola"
DRC_RNA_DNA_plot_df_select <- DRC_RNA_DNA_plot_df %>%
dplyr::select(genus, DNA, RNA, RNA_DNA_ratio, log2_ratio) %>%
dplyr::filter(genus %in% genera_of_interest) %>%
dplyr::mutate(cohort="DRC")
HMP_RNA_DNA_plot_df_select <- HMP_RNA_DNA_plot_df %>%
dplyr::select(genus, DNA, RNA, RNA_DNA_ratio, log2_ratio) %>%
dplyr::filter(genus %in% genera_of_interest) %>%
dplyr::mutate(cohort="HMP")
genera_of_interest_df <- rbind(DRC_RNA_DNA_plot_df_select, HMP_RNA_DNA_plot_df_select) %>%
mutate(genus = factor(genus, levels = genera_of_interest))
ggplot(genera_of_interest_df, aes(x = cohort, y = log2_ratio, fill = cohort)) +
geom_boxplot(outlier.shape = NA, alpha = 0.6) +
geom_jitter(aes(color = cohort), width = 0.2, size = 1, alpha = 0.7) +
facet_wrap(~genus) +
geom_hline(yintercept=1, linetype = "dashed", color = "gray") +
scale_fill_manual(values = c("DRC" = "skyblue", "HMP" = "salmon")) +
scale_color_manual(values = c("DRC" = "skyblue", "HMP" = "salmon")) +
labs(y = "log2(RNA:DNA ratio)") +
theme_linedraw() +
theme(
legend.position = "none",
strip.background = element_blank(),
strip.text = element_text(face = "italic", color = "black")
)
ggsave("figs/HMP_DRC_genuscompare.png", height=3, width=4)
genera_of_interest_stats <- genera_of_interest_df %>%
group_by(genus) %>%
summarise(
p_value = wilcox.test(RNA_DNA_ratio ~ cohort)$p.value
) %>%
ungroup() %>%
# FDR adjustment
mutate(
p_fdr = p.adjust(p_value, method = "fdr"),
significant = ifelse(p_value < 0.05 & p_fdr < 0.05, TRUE, FALSE)
)
genera_of_interest_stats
View(DRC_RNA_DNA_stats)
View(DRC_RNA_DNA_plot_df)
View(plot_stats)
